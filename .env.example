# SportHengelo cross-origin intake token
# Genereer een willekeurig sterk token (bijv. `openssl rand -hex 32`)
# Stel hetzelfde token in als PUBLIC_GH_ISSUES_TOKEN in Cloudflare Pages
INTAKE_TOKEN_SPORTHENGELO=

# Paperclip intake — required in production
PAPERCLIP_API_URL=http://<tailscale-ip>:<port>
PAPERCLIP_API_KEY=your_service_account_api_key_here
PAPERCLIP_COMPANY_ID=<company-uuid>
PAPERCLIP_HELPDESK_AGENT_ID=<agent-uuid>
# Optional: pin issues to a specific project
PAPERCLIP_PROJECT_ID=

# HelpdeskAgent — SMTP (e-mail versturen)
SMTP_HOST=mail.jouwdomein.nl
SMTP_PORT=587
SMTP_USER=helpdesk@jouwdomein.nl
SMTP_PASS=your_smtp_password_here
SMTP_FROM=Helpdesk H.G.V. <helpdesk@jouwdomein.nl>
# SMTP_REPLY_TO=helpdesk@jouwdomein.nl
# SMTP_SECURE=false

# HelpdeskAgent — IMAP (replies ontvangen)
IMAP_HOST=mail.jouwdomein.nl
IMAP_PORT=993
IMAP_USER=helpdesk@jouwdomein.nl
IMAP_PASS=your_imap_password_here
# IMAP_MAILBOX=INBOX