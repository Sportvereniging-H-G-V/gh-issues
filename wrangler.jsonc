{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gh-issues",
  "main": "src/index.js",
  "compatibility_date": "2025-01-01",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "none",
    "run_worker_first": true
  }
}
